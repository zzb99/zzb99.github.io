---
const { project, featured = false, eager = false } = Astro.props;
const projectHref = `/projects/${project.data.slug}/`;
---
<article class:list={['project-card', { 'project-card--featured': featured }]}>
  <a class="project-card__link" href={projectHref} aria-label={`查看项目：${project.data.title}`}>
    <img src={project.data.hero} width="1586" height="991" alt={`${project.data.title}项目主视觉`} loading={eager ? 'eager' : 'lazy'} fetchpriority={eager ? 'high' : 'auto'} decoding="async" />
    <div class="project-card__body">
      <span>{project.data.category} · {project.data.year}</span>
      <h3>{project.data.title}</h3>
      <p>{project.data.summary}</p>
      <b>查看项目 <i>→</i></b>
    </div>
  </a>
  {featured && <div class="apple-store-paddlenav" aria-label="项目轮播控制"><button type="button" class="apple-store-paddlenav__button apple-store-paddlenav__previous" data-project-scroll="previous" aria-label="上一个项目" disabled><img src="/assets/figma-home/ui/inline-arrow.svg" alt="" /></button><button type="button" class="apple-store-paddlenav__button apple-store-paddlenav__next" data-project-scroll="next" aria-label="下一个项目"><img src="/assets/figma-home/ui/inline-arrow.svg" alt="" /></button></div>}
</article>
<script>
  const projectRailWindow = window as Window & { __projectRailInitialized?: boolean };
  if (!projectRailWindow.__projectRailInitialized) {
    projectRailWindow.__projectRailInitialized = true;
    const section = document.querySelector<HTMLElement>('#selected-work');
    const track = section?.querySelector<HTMLElement>('.project-grid--home');
    const controls = section?.querySelector<HTMLElement>('.apple-store-paddlenav');
    const previous = controls?.querySelector<HTMLButtonElement>('[data-project-scroll="previous"]');
    const next = controls?.querySelector<HTMLButtonElement>('[data-project-scroll="next"]');
    if (section && track && controls && previous && next) {
      section.append(controls);
      let pointerActive = false; let dragging = false; let suppressClick = false; let startX = 0; let startScroll = 0;
      const step = () => Math.min(500, track.clientWidth * .82);
      const sync = () => { previous.disabled = track.scrollLeft <= 8; next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8; };
      previous.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
      next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
      track.addEventListener('pointerdown', (event) => { if (event.pointerType !== 'mouse') return; pointerActive = true; startX = event.clientX; startScroll = track.scrollLeft; });
      track.addEventListener('pointermove', (event) => { if (!pointerActive || event.pointerType !== 'mouse') return; const distance = event.clientX - startX; if (!dragging && Math.abs(distance) > 6) { dragging = true; track.setPointerCapture(event.pointerId); track.classList.add('is-dragging'); } if (dragging) track.scrollLeft = startScroll - distance; });
      ['pointerup', 'pointercancel'].forEach((type) => track.addEventListener(type, () => { if (dragging) suppressClick = true; pointerActive = false; dragging = false; track.classList.remove('is-dragging'); }));
      track.addEventListener('click', (event) => { if (!suppressClick) return; suppressClick = false; event.preventDefault(); event.stopPropagation(); }, true);
      track.addEventListener('scroll', sync, { passive: true });
      sync();
    }
  }
</script>
