---
const { project, featured = false } = Astro.props;
const projectHref = `/projects/${project.data.slug}/`;
---

<article class:list={['project-card', { 'project-card--featured': featured }]}>
  <a class="project-card__link" href={projectHref} aria-label={`查看项目：${project.data.title}`}>
    <img src={project.data.hero} alt={`${project.data.title}项目主视觉`} loading="lazy" />
    <div class="project-card__body">
      <span>{project.data.year ? `${project.data.category} · ${project.data.year}` : project.data.category}</span>
      <h3>{project.data.title}</h3>
      <p>{project.data.summary}</p>
      <b>查看项目 <i>→</i></b>
    </div>
  </a>
  {featured && <div class="apple-store-paddlenav" aria-label="项目轮播控制"><button type="button" class="apple-store-paddlenav__button apple-store-paddlenav__previous" data-project-scroll="previous" aria-label="上一个项目" disabled><img src="/assets/figma-home/ui/inline-arrow.svg" alt="" /></button><button type="button" class="apple-store-paddlenav__button apple-store-paddlenav__next" data-project-scroll="next" aria-label="下一个项目"><img src="/assets/figma-home/ui/inline-arrow.svg" alt="" /></button></div>}
</article>

<script>
  if (!(window as Window & { appleStoreProjectRail?: boolean }).appleStoreProjectRail) {
    (window as Window & { appleStoreProjectRail?: boolean }).appleStoreProjectRail = true;
    const section = document.querySelector<HTMLElement>('#selected-work');
    const track = section?.querySelector<HTMLElement>('.project-grid--home');
    const controls = section?.querySelector<HTMLElement>('.apple-store-paddlenav');
    const previous = controls?.querySelector<HTMLButtonElement>('[data-project-scroll="previous"]');
    const next = controls?.querySelector<HTMLButtonElement>('[data-project-scroll="next"]');

    if (section && track && controls && previous && next) {
      section.append(controls);
      let dragging = false;
      let startX = 0;
      let startScroll = 0;
      const step = () => Math.min(500, track.clientWidth * 0.8);
      const sync = () => {
        previous.disabled = track.scrollLeft <= 2;
        next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
      };

      previous.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
      next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
      track.addEventListener('wheel', (event) => {
        const horizontalDelta = event.shiftKey ? event.deltaY : event.deltaX;
        if (!horizontalDelta || (!event.shiftKey && Math.abs(event.deltaX) <= Math.abs(event.deltaY))) return;
        event.preventDefault();
        track.scrollLeft += horizontalDelta;
      }, { passive: false });
      track.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'mouse') return;
        dragging = true;
        startX = event.clientX;
        startScroll = track.scrollLeft;
        track.setPointerCapture(event.pointerId);
        track.classList.add('is-dragging');
      });
      track.addEventListener('pointermove', (event) => {
        if (dragging && event.pointerType === 'mouse') track.scrollLeft = startScroll - (event.clientX - startX);
      });
      ['pointerup', 'pointercancel'].forEach((type) => track.addEventListener(type, () => {
        dragging = false;
        track.classList.remove('is-dragging');
      }));
      track.addEventListener('scroll', sync, { passive: true });
      sync();
    }
  }
</script>
