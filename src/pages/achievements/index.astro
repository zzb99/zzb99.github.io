---
import BaseLayout from '../../layouts/BaseLayout.astro';
const entries = [
  ['ip', '成果沉淀 · 知识产权', '知识产权 11 项', '围绕产品构想、结构设计与项目实践形成的知识产权记录；具体名称与证明材料将在核验后逐步补入。'],
  ['national-awards', '竞赛与荣誉 · 全国级', '2 次全国级奖项经历', '在创新项目的方案表达、材料整理与答辩呈现过程中形成的全国级竞赛经历。'],
  ['provincial-awards', '竞赛与荣誉 · 省部级', '十余次省部级奖项经历', '来自项目实践、竞赛与成果表达的阶段性记录，后续将按时间与项目逐步整理。']
];
const structuredData = { '@context':'https://schema.org', '@type':'ItemList', name:'张智博的成果记录', itemListElement:entries.map(([,,title,copy], index) => ({ '@type':'ListItem', position:index+1, name:title, description:copy })) };
---
<BaseLayout title="成果" description="按知识产权与获奖经历整理的阶段档案。" structuredData={structuredData}><header class="page-hero"><p class="eyebrow">RECORDS</p><h1>成果</h1><p>按知识产权与获奖经历整理的阶段档案，具体材料将随核验逐步归档。</p></header><section class="content-wrap"><div class="achievement-list">{entries.map(([id,kicker,title,copy])=><article id={id} class="achievement"><span>{kicker}</span><strong>{title}</strong><p>{copy}</p></article>)}</div></section></BaseLayout>
