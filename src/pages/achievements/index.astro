---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { intellectualProperty, nationalAwards, provincialAwards } from '../../data/site';
const entries = [...nationalAwards, ...provincialAwards, ...intellectualProperty];
const structuredData = {
  '@context': 'https://schema.org', '@type': 'CollectionPage', name: '张智博的成果与荣誉', url: new URL('/achievements/', Astro.site).href,
  mainEntity: { '@type': 'ItemList', itemListElement: entries.map((entry, index) => ({ '@type': 'ListItem', position: index + 1, name: entry.title, identifier: 'identifier' in entry ? entry.identifier : undefined })) },
};
---
<BaseLayout title="张智博的成果｜获奖、专利与软件著作权" description="汇总张智博可公开核验的获奖记录、实用新型专利、软件著作权及其关联项目。" structuredData={structuredData}>
  <header class="page-hero records-hero"><p class="eyebrow">RECORDS</p><h1>成果与荣誉</h1><p>按名称、年份、编号和项目关系整理。只呈现当前可以明确说明的记录。</p></header>
  <div class="records-page content-wrap">
    <section id="national-awards" class="record-section"><div class="record-section__heading"><p>01</p><h2>国家级荣誉</h2><span>2 项</span></div><div class="record-list">{nationalAwards.map((award) => <article id={award.id}><div><span>{award.year}</span><b>{award.level}</b></div><h3>{award.title}</h3></article>)}</div></section>
    <section id="provincial-awards" class="record-section"><div class="record-section__heading"><p>02</p><h2>省部级荣誉</h2><span>按明确名称列示</span></div><div class="record-list">{provincialAwards.map((award) => <article id={award.id}><div><span>{award.year || '阶段记录'}</span><b>{award.level}</b></div><h3>{award.title}</h3></article>)}</div></section>
    <section id="patents" class="record-section"><div class="record-section__heading"><p>03</p><h2>已公开实用新型专利</h2><span>5 项 · 页面仅列出可公开核验明细</span></div><div class="record-list">{intellectualProperty.filter((item) => item.type !== '软件著作权').map((item) => <article id={item.id}><div><span>{item.type}</span><b>{item.identifier}</b></div><h3>{item.title}</h3><a href={`/projects/${item.project}/`}>查看相关项目 →</a></article>)}</div></section>
    <section id="software" class="record-section"><div class="record-section__heading"><p>04</p><h2>软件著作权</h2><span>1 项</span></div><div class="record-list">{intellectualProperty.filter((item) => item.type === '软件著作权').map((item) => <article id={item.id}><div><span>{item.type}</span><b>{item.identifier}</b></div><h3>{item.title}</h3><a href={`/projects/${item.project}/`}>查看相关项目 →</a></article>)}</div></section>
    <aside class="records-note"><strong>信息说明</strong><p>成果数量按简历中可公开且能够列明的信息整理。省部级荣誉不使用与具体名单矛盾的汇总数字；项目数据应结合对应页面的阶段、角色与边界说明理解。</p></aside>
  </div>
</BaseLayout>
