---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projectOrder } from '../../data/site';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import '../../styles/project-video-hero.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.data.slug }, props: { project } }));
}
const { project } = Astro.props;
const { Content, headings } = await render(project);
const allProjects = await getCollection('projects');
const projects = projectOrder.map((slug) => allProjects.find((item) => item.data.slug === slug)).filter((item): item is NonNullable<typeof item> => Boolean(item));
const index = projects.findIndex((item) => item.id === project.id);
const previous = projects[(index - 1 + projects.length) % projects.length];
const next = projects[(index + 1) % projects.length];
const relatedSlugs = project.data.relatedProjects.length ? project.data.relatedProjects : projects.filter((item) => item.id !== project.id && item.data.category === project.data.category).slice(0, 2).map((item) => item.data.slug);
const related = relatedSlugs.map((slug) => projects.find((item) => item.data.slug === slug)).filter((item): item is NonNullable<typeof item> => Boolean(item)).slice(0, 2);
const hasAnimatedHero = project.data.slug === 'postal-sorting-robot';
const defaultVideo = 'https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260505_101331_74f9b798-3f00-4e86-8a01-377aa16ffeaa.mp4';
const video = project.data.video ?? defaultVideo;
const url = new URL(`/projects/${project.data.slug}/`, Astro.site).href;
const updated = project.data.updatedDate ?? new Date(`${project.data.year.match(/\d{4}/)?.[0] ?? '2025'}-01-01`);
const organizations = project.data.organizations.map((name) => ({ '@type': 'Organization', name }));
const structuredData = [
  { '@context': 'https://schema.org', '@type': 'CreativeWork', name: project.data.title, headline: project.data.seoTitle ?? project.data.title, description: project.data.seoDescription ?? project.data.summary, image: new URL(project.data.hero, Astro.site).href, dateCreated: project.data.year, dateModified: updated.toISOString(), author: { '@id': new URL('/#person', Astro.site).href }, contributor: organizations, locationCreated: project.data.locations.join('、') || undefined, keywords: [project.data.category, ...project.data.organizations].join('、'), url, subjectOf: project.data.sources.map((source) => ({ '@type': 'WebPage', name: source.label, url: source.href })) },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: '首页', item: Astro.site }, { '@type': 'ListItem', position: 2, name: '项目', item: new URL('/projects/', Astro.site).href }, { '@type': 'ListItem', position: 3, name: project.data.title, item: url }] },
];
const subject = encodeURIComponent(`关于「${project.data.title}」的交流`);
---
<BaseLayout title={`${project.data.title}｜张智博项目案例`} description={project.data.seoDescription ?? project.data.summary} image={project.data.hero} ogImageAlt={project.data.title} type="article" structuredData={structuredData}>
  <article class={`project-case project-case--${project.data.slug}`}>
    <Breadcrumbs items={[{ href: '/', label: '首页' }, { href: '/projects/', label: '项目' }, { href: `/projects/${project.data.slug}/`, label: project.data.title }]} />
    <section id="project-overview" class="project-video-hero" aria-labelledby="project-title" style={`--project-poster: url('${project.data.hero}')`}>
      {hasAnimatedHero && <video class="project-video-hero__video" autoplay loop muted playsinline preload="metadata" poster={project.data.hero} aria-hidden="true" data-project-video>
        <source src={video} type="video/mp4" />
      </video>}
      <div class="project-video-hero__veil" aria-hidden="true"></div>
      <header class="project-video-hero__content">
        <p class="eyebrow">{project.data.category.toUpperCase()} · {project.data.year}</p>
        <h1 id="project-title">{project.data.title}</h1>
        <p>{project.data.summary}</p>
        <div class="case-meta"><span>{project.data.status}</span><span>{project.data.role}</span></div>
      </header>
      <nav class="project-video-hero__nav" aria-label="项目页内导航"><a href="#project-overview">项目概览</a><a href="#project-details">核心内容</a><a href="#project-results">项目成果</a></nav>
    </section>

    <div id="project-results" class="case-body">
      <section class="project-facts" aria-labelledby="facts-title">
        <p class="eyebrow">PROJECT FACTS</p><h2 id="facts-title">项目事实</h2>
        <dl><div><dt>时间</dt><dd>{project.data.period ?? project.data.year}</dd></div><div><dt>状态</dt><dd>{project.data.status}</dd></div><div><dt>本人角色</dt><dd>{project.data.role}</dd></div>{project.data.teamContext && <div><dt>协作范围</dt><dd>{project.data.teamContext}</dd></div>}{project.data.organizations.length > 0 && <div><dt>相关单位</dt><dd>{project.data.organizations.join('、')}</dd></div>}{project.data.locations.length > 0 && <div><dt>地点</dt><dd>{project.data.locations.join('、')}</dd></div>}<div><dt>最后更新</dt><dd>{updated.toLocaleDateString('zh-CN')}</dd></div></dl>
        {project.data.evidenceNote && <p class="evidence-note"><strong>数据说明：</strong>{project.data.evidenceNote}</p>}
      </section>
      <div class="metrics">{project.data.metrics.map((item) => <div><b>{item.value}</b><span>{item.label}</span></div>)}</div>
      {headings.length > 0 && <nav class="project-toc" aria-label="项目目录"><b>项目目录</b>{headings.filter((heading) => heading.depth <= 2).map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}</nav>}
      <div id="project-details" class="prose"><Content /></div>
      {project.data.sources.length > 0 && <section class="project-sources"><p class="eyebrow">SOURCES</p><h2>官方资料来源</h2><p>{project.data.sources.map((source, index) => <><a class="text-link" href={source.href} target="_blank" rel="noopener noreferrer">{source.label} <i>→</i></a>{index < project.data.sources.length - 1 && '　'}</>)}</p></section>}
      {project.data.challenge && <section class="project-challenge"><p class="eyebrow">CHALLENGE & RESPONSE</p><h2>实际挑战与处理方式</h2><p><strong>挑战：</strong>{project.data.challenge}</p><p><strong>处理：</strong>{project.data.response}</p></section>}
      {related.length > 0 && <section class="related-projects"><p class="eyebrow">RELATED PROJECTS</p><h2>继续阅读</h2><div>{related.map((item) => <a href={`/projects/${item.data.slug}/`}><span>{item.data.category}</span><b>{item.data.title} →</b></a>)}</div></section>}
      <section class="project-contact"><p class="eyebrow">CONTACT</p><h2>如果这个项目与你正在思考的问题有关</h2><p>可以从具体问题开始交流，不需要准备正式提案。</p><a class="text-link" href={`mailto:zzb9999@outlook.com?subject=${subject}`}>联系我 <i>→</i></a></section>
      <nav class="project-neighbors" aria-label="项目导航"><a href={`/projects/${previous.data.slug}/`}>← 上一项目<br /><b>{previous.data.title}</b></a><a href={`/projects/${next.data.slug}/`}>下一项目 →<br /><b>{next.data.title}</b></a></nav>
      <p><a class="text-link" href="/projects/">返回全部项目 <i>→</i></a></p>
    </div>
  </article>
  {hasAnimatedHero && <script>
    const video = document.querySelector<HTMLVideoElement>('[data-project-video]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const syncVideo = () => { if (!video) return; if (reduceMotion.matches) { video.pause(); video.hidden = true; } else { video.hidden = false; void video.play().catch(() => { video.hidden = true; }); } };
    syncVideo(); reduceMotion.addEventListener('change', syncVideo);
    video?.addEventListener('error', () => { video.hidden = true; });
  </script>}
</BaseLayout>
