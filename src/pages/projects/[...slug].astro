---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() { const projects = await getCollection('projects'); return projects.map(project => ({ params: { slug: project.data.slug }, props: { project } })); }
const { project } = Astro.props;
const { Content, headings } = await render(project);
const projects = (await getCollection('projects')).sort((a,b) => a.data.slug.localeCompare(b.data.slug));
const index = projects.findIndex(item => item.id === project.id);
const previous = projects[(index - 1 + projects.length) % projects.length]; const next = projects[(index + 1) % projects.length];
const related = projects.filter(item => item.id !== project.id).slice(0,2);
const url = new URL(`/projects/${project.data.slug}/`, Astro.site).href;
const structuredData = [{ '@context':'https://schema.org', '@type':'CreativeWork', name:project.data.title, description:project.data.summary, image:new URL(project.data.hero, Astro.site).href, dateCreated:project.data.year, author:{ '@type':'Person', name:'张智博', url:Astro.site }, url }, { '@context':'https://schema.org', '@type':'BreadcrumbList', itemListElement:[{ '@type':'ListItem',position:1,name:'首页',item:Astro.site},{ '@type':'ListItem',position:2,name:'项目',item:new URL('/projects/', Astro.site).href},{ '@type':'ListItem',position:3,name:project.data.title,item:url }] }];
---
<BaseLayout title={project.data.title} description={project.data.summary} image={project.data.hero} type="article" structuredData={structuredData}><article class:list={['project-case', `project-case--${project.data.slug}`]}><header class="case-hero"><p class="eyebrow">{project.data.category.toUpperCase()} · {project.data.year}</p><h1>{project.data.title}</h1><p>{project.data.summary}</p><div class="case-meta"><span>{project.data.status}</span><span>{project.data.role}</span></div></header><figure class="case-cover"><img src={project.data.hero} alt={`${project.data.title}项目主视觉`} /></figure><div class="case-body"><div class="metrics">{project.data.metrics.map(item=><div><b>{item.value}</b><span>{item.label}</span></div>)}</div>{headings.length > 0 && <nav class="project-toc" aria-label="项目目录"><b>项目目录</b>{headings.map(heading=><a href={`#${heading.slug}`}>{heading.text}</a>)}</nav>}<div class="prose"><Content /></div><section class="related-projects"><p class="eyebrow">RELATED PROJECTS</p><h2>继续阅读</h2><div>{related.map(item=><a href={`/projects/${item.data.slug}/`}><span>{item.data.category}</span><b>{item.data.title} →</b></a>)}</div></section><nav class="project-neighbors" aria-label="项目导航"><a href={`/projects/${previous.data.slug}/`}>← 上一项目<br/><b>{previous.data.title}</b></a><a href={`/projects/${next.data.slug}/`}>下一项目 →<br/><b>{next.data.title}</b></a></nav><p><a class="text-link" href="/projects/">返回全部项目 <i>→</i></a></p></div></article></BaseLayout>
