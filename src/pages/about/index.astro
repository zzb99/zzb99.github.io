---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteProfile } from '../../data/site';
const structuredData = {
  '@context': 'https://schema.org', '@type': 'ProfilePage', name: '关于张智博', url: new URL('/about/', Astro.site).href, dateModified: '2026-07-19',
  mainEntity: { '@id': new URL('/#person', Astro.site).href },
};
---
<BaseLayout title="关于张智博｜个人经历、项目实践与创新成果" description="介绍张智博关注的实践方向、做事方式、项目经验、阶段成果与公开联系渠道。" structuredData={structuredData}>
  <article class="about-page" id="person">
    <header class="page-hero"><p class="eyebrow">ABOUT</p><h1>关于</h1><p>保持好奇，也保持探索。</p></header>
    <h2>简介</h2><p class="about-intro">张智博，{siteProfile.graduation}。关注 AI 应用、产品创新、项目运营与真实业务实践，持续记录从问题发现、项目推进到成果落地的过程。</p>
    <h2>关注方向</h2><ul class="about-topics">{siteProfile.knowsAbout.map((topic) => <li>{topic}</li>)}</ul>
    <h2>代表项目</h2><p>本站收录智能分拣、酒店产品创新、非遗数字化、多平台电商与新媒体运营等项目档案；每个页面分别说明背景、参与内容、阶段结果与资料边界。</p>
    <h2>项目与合作经历</h2><p>参与多平台商品运营、酒店新媒体与 OTA 优化、品牌内容与 IP 策划协作，以及阶段性市场拓展等项目实践。相关记录使用“参与”“协作”“项目结果”等中性表述，不将团队成果表述为个人独立完成。</p>
    <div class="about-links"><a href="/projects/">查看项目 <i>→</i></a><a href="/achievements/">查看成果 <i>→</i></a><a href="/articles/">阅读文章 <i>→</i></a></div>
    <h2>官方资料来源</h2><p>竞赛与项目相关的可公开资料均在对应成果或项目页面以“官方来源”或“查看公示”链接标注。</p>
    <h2>联系</h2><p>邮箱：<a class="text-link" href={`mailto:${siteProfile.email}`}>{siteProfile.email}</a><br />官网：<a class="text-link" href={siteProfile.url}>{siteProfile.url}</a><br /><a class="text-link" href="https://github.com/zzb99" target="_blank" rel="noopener noreferrer">GitHub</a>　<a class="text-link" href="https://blog.csdn.net/zhangzhibo9" target="_blank" rel="noopener noreferrer">CSDN</a></p>
    <p class="about-source-link"><a class="text-link" href="/profile/zhang-zhibo/">公开资料与来源 <i>→</i></a></p>
  </article>
</BaseLayout>
