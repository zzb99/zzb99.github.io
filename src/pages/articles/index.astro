---
import { getCollection } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import ArticleCard from '../../components/ArticleCard.astro'; const articles = (await getCollection('articles')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title="文章" description="关于人工智能、产品、内容与项目实践的记录。"><header class="page-hero"><p class="eyebrow">WRITING</p><h1>文章</h1><p>把实践里的观察、方法和还没有定论的问题，慢慢写清楚。</p></header><section class="content-wrap"><div class="article-list">{articles.map(a=><ArticleCard article={a}/>)}</div></section></BaseLayout>
