---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { achievementSummary, faqItems, featuredProjectSlugs, siteProfile } from '../data/site';
import '../styles/home-page.css';

const allProjects = await getCollection('projects');
const projects = featuredProjectSlugs.map((slug) => allProjects.find((project) => project.data.slug === slug)).filter((project): project is NonNullable<typeof project> => Boolean(project));
const articles = (await getCollection('articles')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const structuredData = [{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteProfile.siteName,
  alternateName: siteProfile.brandName,
  url: Astro.site,
  description: siteProfile.description,
  inLanguage: 'zh-CN',
  author: { '@id': new URL('/about/#person', Astro.site).href },
}, {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({ '@type': 'Question', name: item.question, acceptedAnswer: { '@type': 'Answer', text: item.answer } })),
}];
---
<BaseLayout title="张智博｜项目、成果与思考" description={siteProfile.description} structuredData={structuredData} isHome>
  <section class="hero hero--editorial" aria-labelledby="home-title">
    <div class="hero__guide" aria-hidden="true"><span></span><b>01</b></div>
    <div class="hero__content">
      <h1 id="home-title">张智博</h1>
      <p class="hero-subtitle">AI 应用 · 产品创新 · 增长实践</p>
      <p class="hero-copy">保持好奇，也保持探索。</p>
      <div class="hero-links"><a href="/projects/">项目 <i>→</i></a><a href="/articles/">文章 <i>→</i></a></div>
    </div>
    <a class="hero__scroll" href="#selected-work" aria-label="向下查看项目"><span></span></a>
    <div class="hero__transition" aria-hidden="true"></div>
  </section>

  <section id="selected-work" class="section" aria-labelledby="selected-work-title">
    <div class="section-heading"><div><p class="eyebrow">SELECTED WORK</p><h2 id="selected-work-title">项目</h2></div><p>从增长、内容到产品和智能设备，记录具体问题如何被推进。</p></div>
    <div class="project-grid project-grid--home">{projects.map((project, index) => <ProjectCard project={project} featured={index === 0} eager={index === 0} />)}</div>
    <a class="text-link" href="/projects/">查看全部项目 <i>→</i></a>
  </section>

  <section class="section evidence" aria-labelledby="records-title">
    <div class="evidence__heading"><div><p class="eyebrow">SELECTED RECORDS</p><h2 id="records-title">成果记录</h2></div><p>只呈现可以明确说明名称、数量和项目关系的阶段成果。</p></div>
    <div class="evidence-grid">{achievementSummary.map((item) => <a href={item.href}><span>{item.label}</span><strong>{item.value}</strong><p>{item.copy}</p><b>查看成果 <i>→</i></b></a>)}</div>
  </section>

  <section class="section articles-preview" aria-labelledby="writing-title">
    <div class="section-heading"><div><p class="eyebrow">WRITING</p><h2 id="writing-title">最新文章</h2></div><a class="text-link" href="/articles/">全部文章 <i>→</i></a></div>
    <div class="article-list">{articles.map((article) => <ArticleCard article={article} />)}</div>
  </section>

  <section class="section about-teaser"><p class="eyebrow">ABOUT</p><h2>把问题看清，<br />再把事情向前推进。</h2><p>关注新的技术，也关注它们如何进入真实场景。这里保留项目、成果和仍在持续形成的思考。</p><a class="text-link" href="/about/">了解更多 <i>→</i></a></section>

  <section class="section faq" aria-labelledby="faq-title"><div class="section-heading"><div><p class="eyebrow">FAQ</p><h2 id="faq-title">常见问题</h2></div><p>关于张智博、网站内容与联系方法的简要说明。</p></div><div class="faq-list">{faqItems.map((item) => <details><summary>{item.question}</summary><p>{item.answer}</p></details>)}</div></section>
</BaseLayout>
