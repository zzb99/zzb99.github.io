---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import '../styles/home-apple-store-carousel.css';
import '../styles/home-reading-refinement.css';
import { homeAppleCards } from '../data/home-apple-cards';

const projects = homeAppleCards;
const articles = (await getCollection('articles')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const structuredData = { '@context': 'https://schema.org', '@type': 'WebSite', name: '张智博个人网站', url: Astro.site, description: '关注人工智能、产品创新与项目实践。', inLanguage: 'zh-CN', author: { '@type': 'Person', name: '张智博', url: Astro.site } };
---

<style is:global>
@media(max-width:767px){body:has(.hero--editorial) .menu-button{position:relative;width:48px;height:48px;padding:0;font-size:0}body:has(.hero--editorial) .menu-button:before{content:'';position:absolute;top:14px;left:10px;width:28px;height:2px;background:#111;box-shadow:0 9px #111,0 18px #111}}
</style>
<style is:global>
.hero.hero--editorial{min-height:clamp(720px,calc(100svh - 72px),820px);max-width:1440px;margin:0 auto;padding:0 58px;display:grid;grid-template-columns:88px minmax(0,1fr) 88px;align-items:center;text-align:left;background:#fafaf8 url('/images/hero/desktop-hero-background.webp') center center/cover no-repeat}.hero.hero--editorial:after{background:linear-gradient(90deg,rgba(250,250,248,.52),rgba(250,250,248,.24) 30%,rgba(250,250,248,0) 53%)}body:has(.hero--editorial) .site-header{position:absolute;left:0;right:0;background:transparent;backdrop-filter:none}body:has(.hero--editorial) .quiet-contact{display:none}.hero.hero--editorial .hero__content{max-width:620px;padding-left:22px}.hero.hero--editorial h1{font-size:clamp(72px,5.35vw,88px);letter-spacing:.06em;margin-bottom:30px}.hero.hero--editorial .hero-copy{font-size:clamp(24px,1.7vw,28px);line-height:1.55}.hero.hero--editorial .hero-note{font-size:clamp(17px,1.25vw,19px);line-height:1.9}.hero.hero--editorial .hero-links a{display:inline-flex;align-items:center;min-height:44px;font-size:16px;font-weight:600}.hero.hero--editorial .hero__guide{height:62%;align-self:center;padding-top:56px}.hero.hero--editorial .hero__guide:before{width:8px;height:8px}.hero.hero--editorial .hero__guide b{font-size:14px}.hero.hero--editorial .hero__rail{display:none}.hero__scroll{position:absolute;z-index:2;bottom:24px;left:50%;width:44px;height:44px;transform:translateX(-50%);display:grid;place-items:center}.hero__scroll span{width:19px;height:19px;border-right:2px solid #555;border-bottom:2px solid #555;transform:rotate(45deg) translate(-3px,-3px)}@media(min-width:768px) and (max-width:1199px){.hero.hero--editorial{min-height:clamp(680px,calc(100svh - 72px),760px);padding:0 42px;background-position:62% center}.hero.hero--editorial h1{font-size:clamp(62px,7vw,76px)}.hero.hero--editorial .hero-copy{font-size:clamp(20px,2.2vw,24px)}}@media(min-width:768px) and (max-width:1023px) and (orientation:portrait){.hero.hero--editorial{grid-template-columns:64px minmax(0,1fr);min-height:100svh;padding:0 42px;background-image:url('/images/hero/mobile-hero-background.webp');background-position:center bottom}.hero.hero--editorial:after{background:linear-gradient(180deg,rgba(250,250,248,.64),rgba(250,250,248,.08) 64%)}.hero.hero--editorial .hero__content{align-self:start;padding-top:190px;max-width:560px}.hero.hero--editorial .hero__guide{height:57%;align-self:center}}@media(max-width:767px){.hero.hero--editorial{display:grid;grid-template-columns:48px minmax(0,1fr);min-height:100vh;min-height:100svh;padding:0 28px;background-image:url('/images/hero/mobile-hero-background.webp');background-position:center bottom;text-align:left}.hero.hero--editorial:after{background:linear-gradient(180deg,rgba(250,250,248,.68),rgba(250,250,248,.1) 65%)}body:has(.hero--editorial) .site-header .brand{font-size:0}body:has(.hero--editorial) .site-header .brand:after{content:'ZZB';font-size:18px;letter-spacing:.22em}.hero.hero--editorial .hero__content{padding:145px 0 0;align-self:start;margin:0}.hero.hero--editorial h1{font-size:clamp(50px,14vw,58px);letter-spacing:.05em;margin-bottom:43px}.hero.hero--editorial .hero-copy{font-size:clamp(23px,6.5vw,28px);line-height:1.55}.hero.hero--editorial .hero-note{margin-top:36px;font-size:clamp(17px,4.55vw,19px);line-height:1.9}.hero.hero--editorial .hero-links{display:grid;justify-content:start;gap:13px;margin-top:51px}.hero.hero--editorial .hero-links a{font-size:22px;min-height:44px}.hero.hero--editorial .hero__guide{display:flex;height:70%;align-self:center;padding-top:18px}.hero.hero--editorial .hero__guide span{background:#bdbdbc}.hero.hero--editorial .hero__guide b{font-size:16px}.hero.hero--editorial .hero__rail{display:none}}
</style>

<BaseLayout title="张智博" description="关注人工智能、产品创新与项目实践。" structuredData={structuredData}>
  <section class="hero hero--editorial">
    <div class="hero__guide" aria-hidden="true"><span></span><b>01</b></div>
    <div class="hero__content"><h1>张智博</h1><p class="hero-copy">关注人工智能、产品创新与项目实践。</p><p class="hero-note">记录想法如何被理解、被构建，<br/>并最终成为真实的项目与成果。</p><div class="hero-links"><a href="/projects/">查看项目 <i>→</i></a><a href="/articles/">阅读文章 <i>→</i></a></div></div>
    <div class="hero__rail" aria-label="内容索引"><a href="/projects/">想法</a><a href="/projects/">构建</a><a href="/projects/">实践</a><a href="/achievements/">成果</a></div>
    <a class="hero__scroll" href="#selected-work" aria-label="向下查看项目"><span></span></a>
  </section>
  <section id="selected-work" class="section"><div class="section-heading"><div><p class="eyebrow">SELECTED WORK</p><h2>项目</h2></div><p>一些已经完成、正在推进，或仍在持续思考的项目。</p></div><div class="project-grid project-grid--home">{projects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}</div><a class="text-link" href="/projects/">查看全部项目 <i>→</i></a></section>
  <section class="section home-achievements" aria-labelledby="home-achievements-title"><div class="home-achievements__heading"><h2 id="home-achievements-title">Apple Store 有特色，<span>在此选购有的是理由。</span></h2></div><div class="home-achievements__track" aria-label="Apple Store 特色服务"><article class="home-achievement-card home-achievement-card--trade" role="img" aria-label="折抵你的设备，换购新机享优惠。"></article><article class="home-achievement-card home-achievement-card--installments" role="img" aria-label="支付宝新增多家银行支持分期，最长可享 24 个月免息分期。"></article><article class="home-achievement-card home-achievement-card--engraving" role="img" aria-label="这一刻，属于你。混搭表情符号、名字和数字，一起免费刻。"></article><article class="home-achievement-card home-achievement-card--delivery" role="img" aria-label="部分订单可选择三小时快送，或亲自到店取货。所有订单均可享免费送货。"></article><article class="home-achievement-card home-achievement-card--specialist" role="img" aria-label="专属于你的 Apple Specialist 专家。"></article></div></section>
  <script>
    const achievementTrack = document.querySelector<HTMLElement>('.home-achievements__track');
    if (achievementTrack) {
      let activePointer: number | null = null;
      let startX = 0;
      let startScroll = 0;
      achievementTrack.addEventListener('wheel', (event) => {
        if (event.shiftKey || Math.abs(event.deltaX) > Math.abs(event.deltaY)) return;
        event.preventDefault();
        achievementTrack.scrollBy({ left: event.deltaY, behavior: 'auto' });
      }, { passive: false });
      achievementTrack.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'mouse') return;
        activePointer = event.pointerId;
        startX = event.clientX;
        startScroll = achievementTrack.scrollLeft;
        achievementTrack.setPointerCapture(event.pointerId);
        achievementTrack.classList.add('is-dragging');
      });
      achievementTrack.addEventListener('pointermove', (event) => {
        if (activePointer !== event.pointerId) return;
        achievementTrack.scrollLeft = startScroll - (event.clientX - startX);
      });
      const stopDragging = (event: PointerEvent) => {
        if (activePointer !== event.pointerId) return;
        activePointer = null;
        achievementTrack.classList.remove('is-dragging');
      };
      achievementTrack.addEventListener('pointerup', stopDragging);
      achievementTrack.addEventListener('pointercancel', stopDragging);
    }
  </script>
  <section class="section articles-preview"><div class="section-heading"><div><p class="eyebrow">WRITING</p><h2>最新文章</h2></div><a class="text-link" href="/articles/">全部文章 <i>→</i></a></div><div class="article-list">{articles.map((article) => <ArticleCard article={article} />)}</div></section>
  <section class="section evidence"><p class="eyebrow">SELECTED RECORDS</p><h2>成果不是数字墙，<br/>而是项目推进中留下的记录。</h2><div class="evidence-grid"><a href="/achievements/#robotics"><strong>99.2%</strong><span>中邮分拣机器人抓取成功率</span></a><a href="/achievements/#commerce"><strong>300 万元</strong><span>多平台电商双十一单日 GMV</span></a><a href="/achievements/#ip"><strong>11 项</strong><span>国家专利成果</span></a></div></section>
  <section class="section about-teaser"><p class="eyebrow">ABOUT</p><h2>不急着定义身份，<br/>先把正在完成的事留下来。</h2><p>比起给自己一个固定的身份，我更愿意通过持续完成的项目、留下的内容和形成的成果，让这些经历逐渐说明我是谁。</p><a class="text-link" href="/about/">了解更多 <i>→</i></a></section>
</BaseLayout>
