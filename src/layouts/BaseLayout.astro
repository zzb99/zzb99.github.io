---
import '../styles/site.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { nationalAwards, siteProfile } from '../data/site';

const {
  title = siteProfile.siteName,
  description = siteProfile.description,
  image = '/og-default.png',
  type = 'website',
  structuredData,
  isHome = false,
} = Astro.props;
const documentTitle = isHome ? title : title === siteProfile.siteName ? siteProfile.siteName : `${title}｜${siteProfile.siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const absoluteImage = new URL(image, Astro.site);
const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/about/#person', Astro.site).href,
  name: siteProfile.name,
  url: Astro.site,
  description: siteProfile.description,
  email: siteProfile.email,
  sameAs: siteProfile.sameAs,
  affiliation: { '@type': 'CollegeOrUniversity', name: siteProfile.affiliation },
  alumniOf: { '@type': 'CollegeOrUniversity', name: siteProfile.affiliation },
  hasOccupation: { '@type': 'Occupation', name: siteProfile.major },
  knowsAbout: siteProfile.knowsAbout,
  award: nationalAwards.map((award) => award.title),
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: '个人交流',
    email: siteProfile.email,
    availableLanguage: ['zh-CN'],
  },
};
const jsonLd = structuredData ? [person, ...(Array.isArray(structuredData) ? structuredData : [structuredData])] : [person];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fbfbf9" />
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content={siteProfile.siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1"><slot /></main>
    <Footer />
  </body>
</html>
